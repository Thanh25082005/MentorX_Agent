# === Groq API ===
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT=30
GROQ_MAX_RETRIES=3

# === Embedding ===
EMBEDDING_MODEL=all-MiniLM-L6-v2

# === RAG ===
FAISS_INDEX_PATH=data/vector_store
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RAG_TOP_K=3
RAG_DISTANCE_THRESHOLD=1.5

# === Memory ===
SHORT_TERM_MAX_TURNS=20

# === Agent ===
REACT_MAX_ITERATIONS=5
DEBUG_MODE=false

# === Data ===
COURSES_CSV_PATH=data/courses.csv
DOCS_DIR=data/docs
